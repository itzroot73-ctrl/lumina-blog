generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  username      String    @unique
  password      String
  bio           String?
  avatar        String?
  coverImage    String?
  role          String    @default("artist")
  isPremium     Boolean   @default(false)
  walletBalance Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  posts         Post[]
  comments      Comment[]
  likes         Like[]
  donorDonations  Donation[] @relation("DonorDonations")
  artistDonations Donation[] @relation("ArtistDonations")
  sponsorships  Sponsorship[] @relation("SponsorUser")
}

model Post {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String?
  content       String
  thumbnail     String?
  category      String    @default("Tech")
  published     Boolean   @default(false)
  readingTime   Int       @default(5)
  views         Int       @default(0)
  authorId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments      Comment[]
  likes         Like[]
  donations     Donation[]
  sponsorships  Sponsorship[]
}

model Comment {
  id            String    @id @default(cuid())
  content       String
  postId        String
  authorId      String
  createdAt     DateTime  @default(now())
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Like {
  id            String    @id @default(cuid())
  postId        String
  userId        String
  createdAt     DateTime  @default(now())
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Donation {
  id            String    @id @default(cuid())
  amount        Float
  artistAmount  Float
  platformFee   Float
  postId        String
  donorId       String
  artistId      String
  message       String?
  createdAt     DateTime  @default(now())
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  donor         User      @relation("DonorDonations", fields: [donorId], references: [id], onDelete: Cascade)
  artist        User      @relation("ArtistDonations", fields: [artistId], references: [id], onDelete: Cascade)
}

model Sponsorship {
  id            String    @id @default(cuid())
  postId        String
  userId        String
  amount        Float
  duration      Int       @default(24)  // hours
  expiresAt     DateTime
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User      @relation("SponsorUser", fields: [userId], references: [id], onDelete: Cascade)
}
